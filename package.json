{
	"name": "@intenda/opus-ui-website",
	"version": "3.0.0",
	"type": "module",
	"scripts": {
		"start": "concurrently --kill-others \"npm run dev -- --host\" \"node node_modules/@intenda/opus-ui-packager/src/packager.js --watch\"",
		"dev": "vite --port 3000",
		"build-json": "node node_modules/@intenda/opus-ui-packager/src/packager.js",
		"build": "vite build",
		"lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview"
	},
	"opusPackagerConfig": {
		"appDir": "app",
		"packagedDir": "public",
		"packagedFileName": "app"
	},
	"keywords": [
		"opus-ui",
		"website",
		"cms",
		"opus"
	],
	"dependencies": {
		"@intenda/opus-ui": "^3.0.1",
		"@intenda/opus-ui-code-editor": "^3.0.2",
		"@intenda/opus-ui-components": "^3.2.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-compiler-runtime": "^1.0.0"
	},
	"devDependencies": {
		"@intenda/opus-ui-packager": "^1.14.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"concurrently": "^10.0.3",
		"eslint": "^9.20.1",
		"eslint-plugin-react": "^7.37.4",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"vite": "^8.0.16",
		"babel-plugin-react-compiler": "^1.0.0",
		"@intenda/vite-plugin-opus-hot-reload": "^2.2.1"
	},
	"opusComponentLibraries": [
		"opus-ui-code-editor",
		"opus-ui-components"
	],
	"publishConfig": {
		"access": "public"
	}
}
