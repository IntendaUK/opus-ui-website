{
	"acceptPrps": {},
	"scope": "treeview",
	"type": "treeview",
	"traits": [
		{
			"trait": "./functional/staticData"
		}
	],
	"prps": {
		"dtaAtr": "id",
		"disAtr": "name",
		"patAtr": "parentId",
		"childAtr": "children",
		"hideRootNode": true,
		"autoExpand": true,
		"renderExpander": false,
		"mdaLabel": {
			"id": "((rowData.id))label",
			"type": "container",
			"traits": [
				{
					"trait": "./functional/handleBackgroundColorBehaviour",
					"traitPrps": {
						"rowData": "{{rowData}}"
					}
				},
				{
					"trait": "./functional/handleDropDownBehaviour",
					"traitPrps": {
						"rowData": "{{rowData}}"
					}
				}
			],
			"prps": {
				"canClick": true,
				"canHover": true
			},
			"wgts": [
				{
					"id": "((rowData.id))inner",
					"traits": [
						{
							"trait": "./visual/iconAndLabel",
							"traitPrps": {
								"rowData": "{{rowData}}"
							}
						}
					]
				}
			]
		},
		"scps": [
			{
				"id": "sS",
				"triggers": [
					{
						"event": "onMount"
					},
					{
						"event": "onStateChange",
						"source": "||treeview||",
						"key": "mdaChildren"
					},
					{
						"event": "onStateChange",
						"source": "||gettingStarted||",
						"key": "selectedLessonId"
					}
				],
				"actions": [
					{
						"type": "setVariable",
						"name": "selectedArticleId",
						"value": "{{eval.{{state.||gettingStarted||.selectedLessonId}} }}"
					},
					{
						"type": "stopScript",
						"condition": {
							"operator": "isFalsy",
							"value": "{{sS.state.self.data.processed}}"
						}
					},
					{
						"type": "stopScript",
						"condition": {
							"operator": "isFalsy",
							"value": "{{sS.variable.selectedArticleId}}"
						}
					},
					{
						"type": "stopScript",
						"condition": {
							"operator": "isEqual",
							"value": "{{sS.state.self.autoExpandedFor}}",
							"compareValue": "{{sS.variable.selectedArticleId}}"
						}
					},
					{
						"type": "setVariable",
						"name": "targetPath",
						"value": [
							"{{eval.",
							"    const selectedArticleId = {{variable.selectedArticleId}};",
							"    const roots = {{state.self.staticData}} ?? [];",
							"    let path = [];",
							"    const dfs = (nodes, trail) => {",
							"        for (const n of nodes) {",
							"            if (n.dataFile === selectedArticleId) { path = trail; return true; }",
							"            if (n.children && dfs(n.children, [ ...trail, n ])) return true;",
							"        }",
							"        return false;",
							"    };",
							"    dfs(roots, []);",
							"    path.filter(Boolean).map(n => n.id);",
							"}}"
						],
						"inlineKeys": [
							"value"
						]
					},
					{
						"type": "setVariable",
						"name": "newExpanded",
						"value": [
							"{{eval.",
							"    const target = {{variable.targetPath}} ?? [];",
							"    const current = {{state.self.expandedNodes}} ?? [];",
							"    [ ...new Set( [ ...current, ...target ] ) ];",
							"}}"
						],
						"inlineKeys": [
							"value"
						]
					},
					{
						"type": "setState",
						"target": "||treeview||",
						"key": "expandedNodes",
						"value": "{{variable.newExpanded}}"
					},
					{
						"type": "setState",
						"target": "||treeview||",
						"key": "autoExpandedFor",
						"value": "{{variable.selectedArticleId}}"
					}
				]
			}
		]
	}
}
